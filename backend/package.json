{
  "name": "tunetrivia-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TuneTrivia API — highscores, stats och iTunes-preview.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "engines": { "node": ">=20" },
  "dependencies": {
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.0",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
